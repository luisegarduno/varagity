# Consumed twice: Docker Compose interpolates ${vars} for service definitions,
# and the app loads the same file via pydantic-settings (env_file: .env).
#
# Host vs. container hostnames: values below are the IN-CONTAINER ones
# (services address each other by service name). When running the app on the
# HOST (e.g. `uv run main.py`, tests), use the commented host overrides.

# ─────────────────────────────────────────────────────────────
# Docker Compose interpolation vars (lowercase)
# ─────────────────────────────────────────────────────────────
models_volume="/your/models/directory"                # bind-mounted into llama.cpp (read-only)
embeddings_volume="/your/models/directory/embedding"  # bind-mounted into infinity
secret_infinity_key="YOUR INFINITY API KEY"

# ─────────────────────────────────────────────────────────────
# Document ingestion
# ─────────────────────────────────────────────────────────────
DOCS_PATH="/app/docs"                    # container path; host: ./docs
ALLOWED_EXTENSIONS=".pdf,.txt,.md,.rst,.docx,.docm,.dotx,.dotm,.pptx,.pptm,.potx,.potm,.ppsx,.ppsm,.xlsx,.xlsm,.csv,.odt,.ods,.odp,.html,.htm,.xhtml,.png,.jpg,.jpeg,.tif,.tiff,.bmp,.webp"   # office/web (spec_v2 §8) + csv/OpenDocument/xhtml/rst/macro variants/images (OCR)

# ─────────────────────────────────────────────────────────────
# PDF extraction (Docling) — two-pass OCR fallback (plan decision #10)
# ─────────────────────────────────────────────────────────────
PDF_OCR_FALLBACK=true                    # re-convert with OCR when pass 1 finds (near-)no text
PDF_OCR_MIN_CHARS=50                     # < this many non-whitespace chars → "no text layer"
PDF_OCR_TEXTLESS_PAGE_RATIO=0.2          # ≥ this share of textless pages → fallback (mixed docs)
PDF_OCR_FORCE_FULL_PAGE=false            # escape hatch: OCR every page, ignore embedded text
                                         # (corrupt-text-layer PDFs pass the content triggers)
OCR_ENGINE="easyocr"                     # easyocr | tesseract — benchmark-decided default (ADR-004):
                                         # easyocr is error-free where tesseract drops words; tesseract
                                         # is ~5× faster (system binary, installed in the app image)
OCR_LANGUAGES="en"                       # ISO 639-1, comma-separated, primary first (mapped per
                                         # engine, e.g. en → tesseract's eng)

# ─────────────────────────────────────────────────────────────
# Chunking
# ─────────────────────────────────────────────────────────────
CHUNKING_STRATEGY="recursive_character"
CHUNK_SIZE=400                           # characters, not tokens (spec §9.3)
CHUNK_OVERLAP=50

# ─────────────────────────────────────────────────────────────
# Contextual Retrieval
# ─────────────────────────────────────────────────────────────
CONTEXTUALIZE=true                       # LLM situating blurb per chunk (spec §9.4); false = non-contextual
                                         # baseline. Toggling doesn't change content hashes — re-process an
                                         # unchanged corpus with `ingest --reingest`.

# ─────────────────────────────────────────────────────────────
# Embeddings (infinity) — 1024-dim for multilingual-e5-large-instruct
# ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL="infloat/multilingual-e5-large-instruct"  # the SERVED name, verbatim ("infloat")
EMBEDDING_API_URL="http://infinity-embeddings:8081/v1"    # host: http://<bound interface>:8081/v1 (see `docker compose port infinity-embeddings 8081`)
EMBEDDING_API_KEY="${secret_infinity_key}"                # expanded from the var above (compose AND pydantic-settings both interpolate)
EMBEDDING_DIM=1024
EMBEDDING_BATCH_SIZE=32

# ─────────────────────────────────────────────────────────────
# LLM (llama.cpp) — self-hosted
# ─────────────────────────────────────────────────────────────
BASE_MODEL="Qwythos-9B-Claude-Mythos-5-1M-Q8_0.gguf"   # .gguf under ${models_volume}
BASE_MODEL_API_URL="http://llamacpp:8080/v1"             # host: http://localhost:8080/v1
BASE_MODEL_API_KEY="none"                                # llama.cpp runs unauthenticated (dev-only)
MAX_TOKENS=8192
LLM_TEMPERATURE=0.6
LLM_CONTEXT_TOKENS=16384                 # the served context window — interpolated into the llamacpp
                                         # --ctx-size AND read by the app, so the two can't drift;
                                         # generation caps are clamped against it
CONTEXTUALIZE_MAX_TOKENS=2048            # generation cap for per-chunk situating blurbs (reasoning
                                         # preamble + short blurb — NOT the chat-sized MAX_TOKENS)
CHAT_MODEL_TYPE="default"                # default | reasoning | tool — the registry alias chat resolves
                                         # its LLM with (all one llama.cpp server in v2; spec_v2 §4.7)
CHAT_ENGINE="simple"                     # simple | condense_context — chat-engine registry name (spec_v3
                                         # §4.2); simple = search with the user's words verbatim;
                                         # condense_context = rewrite follow-ups into standalone search
                                         # queries against the conversation history
CONDENSE_ENABLED=true                    # kill switch, orthogonal to CHAT_ENGINE (mirrors RERANK_ENABLED):
                                         # false degrades condense_context to simple behavior and logs it
CONDENSE_MODEL_TYPE="default"            # default | reasoning | tool — registry alias the condenser
                                         # resolves its LLM with (one llama.cpp server today; the seam for
                                         # a smaller condenser model later)
CONDENSE_HISTORY_TURNS=6                 # prior messages fed to the condenser (3 user/assistant pairs);
                                         # 0 disables history (no turn ever condenses)
CONDENSE_MAX_TOKENS=512                  # generation cap for the condense call — covers a reasoning
                                         # preamble plus a one-sentence query (a reasoning model burns
                                         # ~215 tokens thinking first; 128 starved it)
CONDENSE_MAX_CHARS=512                   # over this after cleaning ⇒ the condenser misbehaved ⇒ fall
                                         # back to searching with the raw query

# ─────────────────────────────────────────────────────────────
# PostgreSQL + pgvector
# ─────────────────────────────────────────────────────────────
POSTGRES_HOST="postgres"                 # host: localhost
POSTGRES_PORT=5432
POSTGRES_DB="varagity"
POSTGRES_USER="varagity"
POSTGRES_PASSWORD="change-me"

# ─────────────────────────────────────────────────────────────
# Elasticsearch (BM25)
# ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL="http://elasticsearch:9200"            # host: http://localhost:9200
BM25_INDEX_NAME="varagity_contextual_bm25"

# ─────────────────────────────────────────────────────────────
# Retrieval
# ─────────────────────────────────────────────────────────────
RETRIEVAL_METHOD="hybrid"                # semantic | bm25 | hybrid | reranked | hyde
TOP_K=10
SEMANTIC_WEIGHT=0.8                      # hybrid rank-fusion weights (must sum to 1.0)
BM25_WEIGHT=0.2

# Re-ranking (cross-encoder) — served by the same infinity instance at /v1/rerank
# (spec_v2 §5: the ≈67% tier). RETRIEVAL_METHOD=reranked over-fetches
# RERANK_CANDIDATES from RERANK_BASE_METHOD, cross-encodes them, keeps RERANK_TOP_N.
RERANK_ENABLED=false                     # kill switch: false degrades `reranked` to its base method
RERANK_MODEL="BAAI/bge-reranker-v2-m3"   # the SERVED name, verbatim (see INFINITY_SERVED_MODEL_NAME);
                                         # must be a cross-encoder — infinity rejects e5/jina at /rerank
RERANK_API_URL="http://infinity-embeddings:8081/v1"   # host: same bound interface as embeddings
RERANK_API_KEY="${secret_infinity_key}"  # same infinity key as embeddings
RERANK_TOP_N=5                           # documents kept after re-ranking (≤ TOP_K)
RERANK_BASE_METHOD="hybrid"              # semantic | bm25 | hybrid | hyde — the retriever `reranked` composes
RERANK_CANDIDATES=40                     # candidate pool cross-encoded per query (≥ RERANK_TOP_N)

# HyDE (hypothetical document embeddings, ADR-016). RETRIEVAL_METHOD=hyde writes a
# hypothetical answer passage with the chat LLM and steers the DENSE arm with its
# passage-mode embedding — the base method still sees the user's words (BM25 keyword
# recall intact). Pair with the cross-encoder as RETRIEVAL_METHOD=reranked +
# RERANK_BASE_METHOD=hyde (rerank outside, so it judges the real query).
HYDE_ENABLED=true                        # kill switch: false degrades `hyde` to its base method
HYDE_BASE_METHOD="hybrid"                # semantic | hybrid — the retriever `hyde` composes (bm25 ignores vectors)
HYDE_MODEL_TYPE="default"                # default | reasoning | tool — the LLM alias writing passages
HYDE_MAX_TOKENS=1024                     # generation cap (reasoning preamble + 3-5 sentence passage; 512 starved
                                         # ~1/3 of generations on the reasoning model — measured live)
HYDE_MAX_CHARS=2000                      # cleaned-passage ceiling; longer ⇒ misbehaved ⇒ raw-query fallback

# ─────────────────────────────────────────────────────────────
# Prefect (orchestration — flow/task run tracking, UI at :4200)
# ─────────────────────────────────────────────────────────────
PREFECT_API_URL="http://prefect:4200/api"                # host: http://localhost:4200/api

# ─────────────────────────────────────────────────────────────
# HTTP API (FastAPI at :8000 — SSE chat + conversations, spec_v2 §4)
# ─────────────────────────────────────────────────────────────
API_HOST="0.0.0.0"
API_PORT=8000
API_CORS_ORIGINS="http://localhost:3000" # the web app's origin (comma-separated for more)
UPLOAD_MAX_MB=50                         # per-file cap for POST /api/documents
UPLOAD_MAX_FILES=500                     # per-request file-count cap (composer folder attach, spec_v3 §5)
UPLOAD_MAX_TOTAL_MB=2048                 # per-request cap summed across all files (≥ UPLOAD_MAX_MB)
UPLOAD_MAX_PATH_DEPTH=12                 # max path segments (folders + file name) per relative upload path

# ─────────────────────────────────────────────────────────────
# Web GUI (Next.js at :3000, spec_v2 §4)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:8000"  # browser→API origin; BUILD-time constant —
                                             # `docker compose build web` after changing it.
                                             # Browsing from another machine? Use this host's
                                             # LAN address (and add that origin to CORS above).

# ─────────────────────────────────────────────────────────────
# Observability (Prometheus + Grafana, spec_v2 §6)
# ─────────────────────────────────────────────────────────────
METRICS_ENABLED=true                     # gates GET /metrics on the API (collectors always record)
PROMETHEUS_PORT=9090                     # host port for the Prometheus UI/API
GRAFANA_PORT=3001                        # host port for Grafana (container serves 3000);
                                         # dev posture: default admin/admin + anonymous viewing
                                         # Optional exporters are off by default (compose profiles):
                                         #   --profile prefect-exporter  → flow/task-run metrics
                                         #   --profile gpu-metrics       → dcgm-exporter (VRAM/util)

# ─────────────────────────────────────────────────────────────
# Logging & verbosity
# ─────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"
DEFAULT_VERBOSE=1                        # 0 off | 1 low | 2 high
