  "panels": [
    {
      "id": 25,
      "type": "text",
      "title": "Reading this dashboard",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "**Corpus panels** (documents/chunks in corpus) are read from pgvector at scrape time: they survive an API restart and **include CLI ingests**.\n\n**Rate, ratio and latency panels** come from in-process counters: they cover only ingests run through **this API process since it started** (`docker compose restart api` zeroes them), and **CLI ingests are invisible to them** (ADR-007) \u2014 run ingests through the API/GUI to populate those."
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Documents in corpus",
      "description": "Documents currently in pgvector. Store-derived: survives an API restart and counts CLI ingests too.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "noValue": "\u2014",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(varagity_corpus_documents)",
          "legendFormat": "",
          "instant": true,
          "range": false
        }
      ]
    },
    {
