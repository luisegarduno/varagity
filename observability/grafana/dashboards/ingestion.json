          "expr": "sum(varagity_corpus_chunks)",
          "legendFormat": "",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 11,
      "type": "stat",
      "title": "OCR-fallback rate (this API process)",
      "description": "Share of documents whose text came from OCR rather than a digital text layer. Counter-derived, so this covers only ingests run through THIS API process since it started \u2014 not the corpus at large.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "thresholds"
          },
          "noValue": "\u2014",
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "red",
                "value": 0.7
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(varagity_ingest_docs_total{extraction=\"ocr_fallback\"}) / sum(varagity_ingest_docs_total)",
          "legendFormat": "",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Documents in corpus by file type",
      "description": "Corpus composition by format (pdf/txt/md + the v2 office/web modalities).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineInterpolation": "stepAfter"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (file_type) (varagity_corpus_documents_by_type)",
          "legendFormat": "{{file_type}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Chunks in corpus by strategy",
      "description": "Corpus composition by the chunker that produced each chunk. Mixed strategies mean the corpus predates a CHUNKING_STRATEGY change without a --reingest.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineInterpolation": "stepAfter"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (chunking_strategy) (varagity_corpus_chunks_by_strategy)",
          "legendFormat": "{{chunking_strategy}}"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Contextualization latency per document",
      "description": "Per-document blurb generation latency (API-process ingests only). Uses the full dashboard range: ingestion is bursty, and a ~1m rate window rarely straddles a run.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(varagity_contextualize_latency_seconds_bucket[$__range])))",
          "legendFormat": "p95"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.5, sum by (le) (rate(varagity_contextualize_latency_seconds_bucket[$__range])))",
          "legendFormat": "median"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Contextualization seconds per chunk (cumulative)",
      "description": "Mean blurb-generation cost per chunk since this API process started (API-process ingests only). Deliberately increase()-free: the chunk counter is born at its full value after a restart, so increase() over it is 0 and the ratio would read +Inf.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 18
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(varagity_contextualize_latency_seconds_sum) / sum(varagity_ingest_chunks_total)",
          "legendFormat": "s/chunk"
        }
      ]
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Last ingest run \u00b7 finished",
      "description": "When the last API-driven ingest run completed. Reads 'never' until one completes in this API process.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 29
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso",
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          },
          "noValue": "never since API start",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "never since API start",
                  "index": 0
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
