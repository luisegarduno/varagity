    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Prefect totals \u2014 prefect-exporter profile",
      "description": "Prefect object counts from the optional exporter. deployments reads 0 forever by design \u2014 flows run in-process from the CLI/API, so there are no deployments (or work pools) to count. flow runs counts only runs started within OFFSET_MINUTES (24 h in this compose); flows is unwindowed.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
