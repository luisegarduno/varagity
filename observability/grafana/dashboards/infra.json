{
  "uid": "varagity-infra",
  "title": "Varagity \u00b7 Infra",
  "tags": [
    "varagity"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    {
      "type": "dashboards",
      "title": "Varagity dashboards",
      "tags": [
        "varagity"
      ],
      "asDropdown": true,
      "includeVars": false,
      "keepTime": true,
      "icon": "external link",
      "targetBlank": false,
      "tooltip": "",
      "url": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 16,
      "type": "state-timeline",
      "title": "Backing services (last health probe)",
      "description": "Reachability of each backing service at its last probe. Refreshed at least every 15 s by the api container's own healthcheck.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 14,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "down",
                  "color": "red",
                  "index": 1
                },
                "1": {
                  "text": "up",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "custom": {
            "lineWidth": 0,
            "fillOpacity": 70,
            "spanNulls": false
          },
          "noValue": "no probe yet"
        },
        "overrides": []
      },
      "options": {
        "showValue": "auto",
        "alignValue": "center",
        "mergeValues": true,
        "rowHeight": 0.85,
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "varagity_dependency_up",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Scrape targets",
      "description": "Prometheus's own view of its scrape targets. The optional prefect-exporter / dcgm-exporter jobs read 0 while their compose profile is disabled.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 14,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "noValue": "\u2014",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "down",
                  "color": "red",
                  "index": 1
                },
                "1": {
                  "text": "up",
                  "color": "green",
                  "index": 0
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "up",
          "legendFormat": "{{job}}",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "GPU utilization \u2014 dcgm-exporter profile",
      "description": "Populated when the gpu-metrics compose profile is enabled. Consumer-card caveat: several DCGM fields are empty on GeForce parts.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}} {{modelName}}"
        }
      ]
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "GPU VRAM used \u2014 dcgm-exporter profile",
      "description": "Framebuffer in use per GPU (MiB). Answers the runbook's 'is llama.cpp starving infinity?' question when the gpu-metrics profile is on.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mbytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "DCGM_FI_DEV_FB_USED",
          "legendFormat": "GPU {{gpu}} {{modelName}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Prefect flow runs by state \u2014 prefect-exporter profile",
      "description": "Populated when the prefect-exporter compose profile is enabled \u2014 orchestration-level run states polled from the Prefect API.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (state_name) (prefect_info_flow_runs)",
          "legendFormat": "{{state_name}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Prefect totals \u2014 prefect-exporter profile",
      "description": "Cumulative Prefect object counts from the optional exporter.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "prefect_flow_runs_total",
          "legendFormat": "flow runs"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "prefect_flows_total",
          "legendFormat": "flows"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "prefect_deployments_total",
          "legendFormat": "deployments"
        }
      ]
    }
  ]
}
